# Python
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.venv/

# Local runtime state (regenerable; raw corpus lives elsewhere, never committed)
data/
*.duckdb
*.duckdb.wal
*.lance/

# Secrets never live in the repo — Keychain/env only (Invariant 10). Belt and suspenders:
.env
*.secret

# Per-machine config overlay (config/loader.py): enables [secrets]/[attestation] on a deployment
# without flipping the shared safe defaults. Never shared — a fresh clone stays off-by-default.
config/local.toml
# Machine-owned knob overlay, written only by the self-modification loop (ops/apply.py) through
# the §14 gate. Per-machine runtime state, regenerable; never committed.
config/levers.toml

# OS / packaging cruft
.DS_Store
mind-palace.zip

# Terraform local state — `.terraform/` holds downloaded provider binaries (100s of MB, one per
# platform) and is pure local cache; tfstate is remote (S3 backend) except a harmless backend
# bookkeeping file terraform sometimes drops locally. The lock file (.terraform.lock.hcl) is NOT
# ignored — that one is meant to be committed (pins provider versions).
**/.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.claude/settings.local.json

# delegated-builder worktrees (delegate skill) — transient, never committed
.claude/worktrees/

# mkdocs local build output (bp-017 §6(a); published via the pages workflow, never tracked — finding-0045)
public/

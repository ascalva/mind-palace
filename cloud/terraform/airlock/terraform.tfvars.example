# Copy to terraform.tfvars and adjust. All values have sensible defaults; the one worth
# setting for real least privilege is the bridge trust principal.

# region              = "us-east-1"
# airlock_bucket_name = "mind-palace-airlock-054942746160"
# object_retention_days = 14
# lambda_runtime      = "python3.12"

# RECOMMENDED: narrow the bridge role's trust to your SSO permission-set role ARN instead of
# the account root. Find it with:
#   aws sts get-caller-identity --profile alberto-sso
# bridge_trusted_principal_arns = [
#   "arn:aws:iam::054942746160:role/aws-reserved/sso.amazonaws.com/AWSReservedSSO_<perm-set>_<id>",
# ]

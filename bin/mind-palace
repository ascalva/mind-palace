#!/usr/bin/env bash
# Single front door for every mind-palace script: `mind-palace <verb> [args...]` from anywhere.
# Resolves the real repo root from this script's own location (follows the PATH symlink), then
# dispatches to the right script under scripts/ with the right interpreter. `mind-palace help`
# lists every verb — no more hunting for which file does what.
set -euo pipefail

src="${BASH_SOURCE[0]}"
while [ -L "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
REPO_ROOT="$(cd -P "$(dirname "$src")/.." >/dev/null 2>&1 && pwd)"
# uv owns env resolution (CONVENTIONS §Language); shim may run outside the repo cwd.
py() { exec /opt/homebrew/bin/uv run --directory "$REPO_ROOT" python "$@"; }
SCRIPTS="$REPO_ROOT/scripts"

usage() {
  cat <<'EOF'
mind-palace <verb> [args...]   — run from any directory

DAY-TO-DAY
  start | stop | status | reset [--force|--confirm]    the supervised lifecycle (scripts/palace.py)
  talk [--offline]                                      interactive chat (--offline = no-Ollama demo)
  monitor                                                run the dashboard/chat HTTP server standalone
  sandbox <code.py|-> [--input NAME=PATH] [--timeout N]  run code in the powerless sandbox

INGEST / KNOWLEDGE
  ingest                                                 (re)build the knowledge base from the vault
  ingest-self-knowledge                                  ingest docs/ so "how do you work?" is grounded
  migrate-provenance [--apply]                           relabel legacy authored rows (moot post-reset)
  purge-raw <digest> --confirm | --list                  owner-gated TRUE deletion of a tombstoned blob

SECURITY / AUDIT
  gen-attestation-keys <supervisor|owner>                generate + print an Ed25519 signing seed
  verify-attestation <id> | --all | --list               verify the attestation chain
  check-imports                                          the import-firewall lint (Invariant 2)
  run-with-secrets <cmd...>                              inject Keychain secrets, then exec <cmd...>

EVAL / OPS
  eval [--bless]                                         score the frozen golden set
  build-sandbox-image [tag]                              build the scientific-libs sandbox image
  keep-awake [-- <cmd>]                                  block system sleep (optionally just for <cmd>)
  watch                                                  ⚠ deprecated — superseded by `start`

  help | -h | --help                                     this message
EOF
}

verb="${1:-}"
if [ "$#" -gt 0 ]; then shift; fi

case "$verb" in
  ""|help|-h|--help) usage ;;
  start|stop|status|reset|deploy)  py "$SCRIPTS/palace.py" "$verb" "$@" ;;
  talk)                     py "$SCRIPTS/talk.py" "$@" ;;
  supersede)                py "$SCRIPTS/supersede.py" "$@" ;;
  monitor)                  py "$SCRIPTS/monitor.py" "$@" ;;
  sandbox)                  py "$SCRIPTS/sandbox.py" "$@" ;;
  ingest)                   py "$SCRIPTS/ingest.py" "$@" ;;
  ingest-self-knowledge)    py "$SCRIPTS/ingest_self_knowledge.py" "$@" ;;
  migrate-provenance)       py "$SCRIPTS/migrate_provenance_split.py" "$@" ;;
  purge-raw)                py "$SCRIPTS/purge_raw.py" "$@" ;;
  gen-attestation-keys)     py "$SCRIPTS/gen_attestation_keys.py" "$@" ;;
  verify-attestation)       py "$SCRIPTS/verify_attestation.py" "$@" ;;
  check-imports)            py "$SCRIPTS/check_imports.py" "$@" ;;
  run-with-secrets)         exec "$SCRIPTS/run_with_secrets.sh" "$@" ;;
  eval)                     py "$SCRIPTS/eval.py" "$@" ;;
  build-sandbox-image)      exec "$SCRIPTS/build_sandbox_image.sh" "$@" ;;
  keep-awake)               exec "$SCRIPTS/keep-awake.sh" "$@" ;;
  watch)
    echo "⚠ scripts/watch.py is superseded by 'mind-palace start' (which now manages the watcher" >&2
    echo "  + everything else as one supervised process). Running it standalone anyway:" >&2
    py "$SCRIPTS/watch.py" "$@" ;;
  *)
    echo "mind-palace: unknown verb '$verb'" >&2
    usage >&2
    exit 2 ;;
esac

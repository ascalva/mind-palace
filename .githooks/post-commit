#!/bin/sh
# Structural code snapshot on every commit (ops/code_snapshot.py). NEVER blocks a commit:
# a failed snapshot prints a warning and exits 0 — the ledger is backfillable by SHA later.
cd "$(git rev-parse --show-toplevel)" || exit 0
./.venv/bin/python scripts/snapshot_code.py HEAD 2>&1 || echo "code-snapshot failed (non-blocking; run scripts/snapshot_code.py --backfill to catch up)"
exit 0
